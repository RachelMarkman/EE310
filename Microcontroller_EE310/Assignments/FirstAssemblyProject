;---------------------------------
; Title: Assembly Program Project
;---------------------------------
; Purpose: This program compares a reference temperature and a measured temperature.
; Dependencies: NONE
; Compiler: MPLAB X IDE v6.30
; Author: Rachel Markman
; OUTPUTS: RD1 is connected to a Heating LED. RD2 is connected to a Cooling LED.
; INPUTS: measuredTempInput and refTempInput (both constants).
; Versions:
;   V1.0: 3/9/26 - First version 
;   V1.1: 3/10/26 - Fixed errors
;   V1.2: 3/11/26 - Fixed more errors

#include <xc.inc>

PSECT resetVec,class=CODE,reloc=2
resetVec:
    goto start	    ;jumps to main program

PSECT code
start:

;----------------
; Program Inputs
;----------------
#define measuredTempInput  -5
#define refTempInput       15
		    
;-------------
; Definitions
;-------------
#define SWITCH LATD,2
#define LED0   PORTD,0
#define LED1   PORTD,1 
    
;-------------------    
; Program Constants
;-------------------    
    
REG10   EQU     10h	;temp storage for refTemp conversion
REG11   EQU     11h	;temp storage for measuredTemp conversion
REG01   EQU     1h

;-----------
; Main Code
;-----------      

;initializing PORTD
    CLRF    TRISD
    CLRF    LATD
    
;loading inputs into register
    MOVLW   refTempInput
    MOVWF   0x20
    MOVLW   measuredTempInput
    MOVWF   0x21
    
;comparing measuredTemp - refTemp  (CORRECTED)
    MOVF    0x20, W        ; W = refTemp
    SUBWF   0x21, W        ; W = measuredTemp - refTemp
    
    BZ	    TEMPSEQUAL		;measuredTemp=refTemp
    BC	    measuredTempGREATER	;measuredTemp>refTemp
    BRA	    measuredTempLESS	;measurdTemp<refTemp

;creating functions
TEMPSEQUAL: ;led off
    CLRF    0x22	;contreg=0
    BCF	    LATD,1
    BCF	    LATD,2
    BRA	    CONTINUE

measuredTempGREATER: ;cooling ON
    MOVLW   0x02
    MOVWF   0x22	;contreg=2
    BSF	    LATD,2
    BCF	    LATD,1
    BRA	    CONTINUE

measuredTempLESS: ;heating ON
    MOVLW   0x01
    MOVWF   0x22	;contreg=1
    BSF	    LATD,1
    BCF	    LATD,2
    BRA	    CONTINUE
    
CONTINUE:

;HEX to Decimal Conversion (refTemp)

    CLRF    0x60    ;clears 1's digit
    CLRF    0x61    ;clears 10's digit
    CLRF    0x62    ;clears 100's digit

    MOVF    0x20, W	;loads refTemp
    MOVWF   REG10	;moves refTemp

REFTENLOOP:
    MOVLW   10	
    SUBWF   REG10, F
    BNC	    REFSTORE	;stops when borrow occurs
    INCF    0x61, F	;increments 10's
    BRA	    REFTENLOOP

REFSTORE:
    MOVLW   10
    ADDWF   REG10, F	;resotres last sub
    MOVF    REG10, W
    MOVWF   0x60	;stores 1's digit

;converting measuredTempInput

    CLRF    0x70	;clears 1's digit
    CLRF    0x71	;clears 10's digit
    CLRF    0x72	;clears 100's digit
    
    MOVF    0x21, W	;loads measuredTemp
    MOVWF   REG11	;moves measuredTemp
    
MEASUREDTENLOOP:
    MOVLW   10
    SUBWF   REG11, F
    BNC	    MEASUREDSTORE 
    INCF    0x71, F	    ;increment 10's
    BRA	    MEASUREDTENLOOP

MEASUREDSTORE:
    MOVLW   10
    ADDWF   REG11, F
    MOVF    REG11, W
    MOVWF   0x70	;stores 1's digit
    
;ending program
ENDPROGRAM:
    BRA	    ENDPROGRAM
    
    END
